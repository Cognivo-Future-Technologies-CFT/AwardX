# ============================================================================
# AWARDX FRONTEND ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and replace the placeholder values with your actual keys
# ============================================================================

# ======================
# API CONFIGURATION
# ======================

# Backend API URL (Proxy Server)
VITE_API_URL=http://localhost:5000

# ======================
# SITE CONFIGURATION
# ======================

# Site URL for auth redirects (your app's URL)
VITE_SITE_URL=http://localhost:3000

# ======================
# ANALYTICS (Optional)
# ======================

# Google Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel
# VITE_MIXPANEL_TOKEN=your-mixpanel-token

# ======================
# MISC
# ======================

# App environment
VITE_APP_ENV=development

# Enable debug logging
VITE_DEBUG=false

# ============================================================================
# IMPORTANT SECURITY NOTE
# ============================================================================
# Database credentials (Supabase keys) are NO LONGER stored in the frontend
# They are now securely stored in the backend server (see server/.env)
# This prevents exposure of sensitive credentials in client-side code
# ============================================================================

