# Server
PORT=5001
NODE_ENV=production
# Comma-separated allowed frontend origins for CORS
FRONTEND_URL=https://your-frontend.example.com
# Canonical site URL for emails, OAuth redirects, payment callbacks
SITE_URL=https://your-frontend.example.com

# Supabase (required)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (optional — per-org Resend keys are stored in Supabase)
RESEND_API_KEY=
RESEND_FROM=AwardX <no-reply@yourdomain.com>
RESEND_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay (direct keys + OAuth)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_OAUTH_CLIENT_ID=
RAZORPAY_OAUTH_CLIENT_SECRET=
RAZORPAY_OAUTH_REDIRECT_URI=
RAZORPAY_OAUTH_MODE=test

# Didit KYC
DIDIT_API_KEY=
DIDIT_API_BASE_URL=
DIDIT_WEBHOOK_SECRET=
ALLOW_KYC_DEMO=false

# Encryption for stored integration secrets
API_ENCRYPTION_KEY=

# Redis cache (optional)
REDIS_ENABLED=false
REDIS_URL=
REDIS_TOKEN=
REDIS_USERNAME=default
REDIS_NAMESPACE=awardx

# Round advancement
ROUND_ADVANCEMENT_TX_ENABLED=false
